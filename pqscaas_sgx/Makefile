##############################################################################
# PQSCAAS SGX Experiment Suite — Makefile
#
# Usage:
#   source /opt/intel/sgxsdk/environment
#   make SGX_MODE=SIM             # build in simulation mode (default)
#   make SGX_MODE=HW              # build for hardware (requires SGX CPU)
#   make clean
#   ./pqscaas_experiments         # run all 8 experiments
#   ./pqscaas_experiments --exp 1 2 7
#   python3 plot_all.py           # generate figures from CSVs
##############################################################################

SGX_SDK    ?= /opt/intel/sgxsdk
SGX_MODE   ?= SIM
SGX_ARCH   ?= x64
SGX_DEBUG  ?= 1

# Paths
SGX_LIBRARY_PATH := $(SGX_SDK)/lib64
SGX_ENCLAVE_SIGNER := $(SGX_SDK)/bin/x64/sgx_sign
SGX_EDGER8R := $(SGX_SDK)/bin/x64/sgx_edger8r

# SGX mode flags
ifeq ($(SGX_MODE), HW)
    Trts_Library_Name  := sgx_trts
    Service_Library    := sgx_tservice
    Urts_Library_Name  := sgx_urts
    UAE_Service_Name   := sgx_uae_service
else
    Trts_Library_Name  := sgx_trts_sim
    Service_Library    := sgx_tservice_sim
    Urts_Library_Name  := sgx_urts_sim
    UAE_Service_Name   := sgx_uae_service_sim
endif

ifeq ($(SGX_DEBUG), 1)
    SGX_COMMON_FLAGS := -O0 -g
    SGX_DEBUG_FLAG   := 1
else
    SGX_COMMON_FLAGS := -O2
    SGX_DEBUG_FLAG   := 0
endif

SGX_COMMON_FLAGS += -Wall -Wextra -Wno-unused-parameter \
                    -m64 -fstack-protector

# --------------------------------------------------------------------------
# ENCLAVE (trusted) compilation
# --------------------------------------------------------------------------
ENCLAVE_DIR        := enclave
TRUSTED_DIR        := $(ENCLAVE_DIR)/trusted
ENCLAVE_EDL        := $(ENCLAVE_DIR)/pqscaas_enclave.edl
ENCLAVE_CONFIG     := $(ENCLAVE_DIR)/pqscaas_enclave.config.xml
ENCLAVE_SIGNING_KEY:= $(ENCLAVE_DIR)/pqscaas_enclave_private.pem

TRUSTED_INC := -I$(SGX_SDK)/include               \
               -I$(SGX_SDK)/include/tlibc          \
               -I$(SGX_SDK)/include/libcxx         \
               -I$(TRUSTED_DIR)

TRUSTED_CXXFLAGS := $(SGX_COMMON_FLAGS) $(TRUSTED_INC)  \
                    -nostdinc++ -fno-rtti -fno-exceptions \
                    -fPIC -fno-builtin-printf

TRUSTED_LDFLAGS := -Wl,--no-undefined -nostdlib -nodefaultlibs -nostartfiles \
                   -L$(SGX_LIBRARY_PATH)                                      \
                   -Wl,--whole-archive -l$(Trts_Library_Name) -Wl,--no-whole-archive \
                   -Wl,--start-group                                           \
                   -lsgx_tstdc -lsgx_tcxx -lsgx_tcrypto -l$(Service_Library) \
                   -Wl,--end-group                                             \
                   -Wl,-Bstatic -Wl,-Bsymbolic -Wl,--no-undefined             \
                   -Wl,-pie,-eenclave_entry -Wl,--export-dynamic               \
                   -Wl,--defsym,__ImageBase=0

TRUSTED_SRCS := $(TRUSTED_DIR)/pqscaas_enclave.cpp \
                $(TRUSTED_DIR)/crypto_primitives.cpp

TRUSTED_OBJS := $(TRUSTED_SRCS:.cpp=.o)

# Generated by edger8r
TRUSTED_GEN_DIR  := $(TRUSTED_DIR)
UNTRUSTED_GEN_DIR:= untrusted

# --------------------------------------------------------------------------
# UNTRUSTED (host) compilation
# --------------------------------------------------------------------------
UNTRUSTED_DIR := untrusted

UNTRUSTED_INC := -I$(SGX_SDK)/include                \
                 -I$(SGX_SDK)/include/ipp             \
                 -I$(UNTRUSTED_DIR)                   \
                 -I$(TRUSTED_DIR)

UNTRUSTED_CXXFLAGS := $(SGX_COMMON_FLAGS) $(UNTRUSTED_INC) \
                      -std=c++17 -fPIC

UNTRUSTED_LDFLAGS := -L$(SGX_LIBRARY_PATH)       \
                     -l$(Urts_Library_Name)       \
                     -l$(UAE_Service_Name)        \
                     -lpthread -lm                \
                     -lssl -lcrypto               \
                     -Wl,-rpath,$(SGX_LIBRARY_PATH)

UNTRUSTED_SRCS := $(UNTRUSTED_DIR)/main.cpp       \
                  $(UNTRUSTED_DIR)/experiments.cpp \
                  $(UNTRUSTED_DIR)/baselines.cpp   \
                  $(UNTRUSTED_DIR)/aead.cpp

UNTRUSTED_OBJS := $(UNTRUSTED_SRCS:.cpp=.o)

# --------------------------------------------------------------------------
# Targets
# --------------------------------------------------------------------------
TARGET_BIN    := pqscaas_experiments
TARGET_ENCLAVE:= pqscaas_enclave.so
TARGET_SIGNED := pqscaas_enclave.signed.so

.PHONY: all clean distclean check_env

all: check_env $(TARGET_BIN) $(TARGET_SIGNED)
	@echo ""
	@echo "Build complete (SGX_MODE=$(SGX_MODE))"
	@echo "Run:  ./$(TARGET_BIN)"

# --- SGX environment check ---
check_env:
	@test -d $(SGX_SDK) || (echo "ERROR: SGX SDK not found at $(SGX_SDK)"; \
	    echo "Install it and run: source $(SGX_SDK)/environment"; exit 1)

# --- Generate EDL bridge code ---
$(TRUSTED_DIR)/pqscaas_enclave_t.h \
$(TRUSTED_DIR)/pqscaas_enclave_t.c: $(ENCLAVE_EDL)
	@echo "[edger8r] Generating trusted bridge..."
	$(SGX_EDGER8R) --trusted $(ENCLAVE_EDL) \
	    --trusted-dir $(TRUSTED_GEN_DIR)    \
	    --search-path $(SGX_SDK)/include

$(UNTRUSTED_DIR)/pqscaas_enclave_u.h \
$(UNTRUSTED_DIR)/pqscaas_enclave_u.c: $(ENCLAVE_EDL)
	@echo "[edger8r] Generating untrusted bridge..."
	$(SGX_EDGER8R) --untrusted $(ENCLAVE_EDL) \
	    --untrusted-dir $(UNTRUSTED_GEN_DIR)   \
	    --search-path $(SGX_SDK)/include

# --- Trusted C bridge (from edger8r) ---
$(TRUSTED_DIR)/pqscaas_enclave_t.o: $(TRUSTED_DIR)/pqscaas_enclave_t.c
	@echo "[CC trusted]  $<"
	$(CC) $(TRUSTED_CXXFLAGS) -c $< -o $@

# --- Trusted C++ sources ---
$(TRUSTED_DIR)/%.o: $(TRUSTED_DIR)/%.cpp \
    $(TRUSTED_DIR)/pqscaas_enclave_t.h
	@echo "[CXX trusted] $<"
	$(CXX) $(TRUSTED_CXXFLAGS) -std=c++11 -c $< -o $@

# --- Link enclave shared object ---
$(TARGET_ENCLAVE): $(TRUSTED_OBJS) $(TRUSTED_DIR)/pqscaas_enclave_t.o
	@echo "[LD  enclave] $@"
	$(CXX) $^ -o $@ $(TRUSTED_LDFLAGS)

# --- Generate signing key if absent ---
$(ENCLAVE_SIGNING_KEY):
	@echo "[keygen] Generating enclave signing key (development only)..."
	openssl genrsa -3 -out $@ 3072

# --- Sign enclave ---
$(TARGET_SIGNED): $(TARGET_ENCLAVE) $(ENCLAVE_SIGNING_KEY) $(ENCLAVE_CONFIG)
	@echo "[sign  enclave] $@"
	$(SGX_ENCLAVE_SIGNER) sign                    \
	    -key  $(ENCLAVE_SIGNING_KEY)               \
	    -enclave $(TARGET_ENCLAVE)                 \
	    -out  $@                                   \
	    -config $(ENCLAVE_CONFIG)

# --- Untrusted C bridge (from edger8r) ---
$(UNTRUSTED_DIR)/pqscaas_enclave_u.o: $(UNTRUSTED_DIR)/pqscaas_enclave_u.c
	@echo "[CC untrusted] $<"
	$(CC) $(UNTRUSTED_CXXFLAGS) -c $< -o $@

# --- Untrusted C++ sources ---
$(UNTRUSTED_DIR)/%.o: $(UNTRUSTED_DIR)/%.cpp \
    $(UNTRUSTED_DIR)/pqscaas_enclave_u.h
	@echo "[CXX untrusted] $<"
	$(CXX) $(UNTRUSTED_CXXFLAGS) -c $< -o $@

# --- Link final binary ---
$(TARGET_BIN): $(UNTRUSTED_OBJS) $(UNTRUSTED_DIR)/pqscaas_enclave_u.o
	@echo "[LD  binary  ] $@"
	$(CXX) $^ -o $@ $(UNTRUSTED_LDFLAGS)

# --------------------------------------------------------------------------
clean:
	rm -f $(TRUSTED_OBJS) $(UNTRUSTED_OBJS)
	rm -f $(TRUSTED_DIR)/pqscaas_enclave_t.{h,c,o}
	rm -f $(UNTRUSTED_DIR)/pqscaas_enclave_u.{h,c,o}
	rm -f $(TARGET_BIN) $(TARGET_ENCLAVE) $(TARGET_SIGNED)

distclean: clean
	rm -rf results/ figures/
